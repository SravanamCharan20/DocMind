{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "rag-service",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd rag-service && venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000"],
      "port": 8000
    },
    {
      "name": "backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && node index.js"],
      "port": 5050
    },
    {
      "name": "frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd frontend && npm run dev"],
      "port": 3000
    }
  ]
}
